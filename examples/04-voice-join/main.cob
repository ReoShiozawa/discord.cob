       IDENTIFICATION DIVISION.
       PROGRAM-ID. EXAMPLE-VOICE-JOIN.
       *> JP: Main Gateway から Voice Gateway/UDP negotiation までを実行する例です。
       *> EN: Runnable example from Main Gateway login through Voice/UDP negotiation.

       DATA DIVISION.
       WORKING-STORAGE SECTION.
       COPY "discord-client.cpy".
       COPY "discord-result.cpy".
       01 WS-GUILD-ID PIC X(32).
       01 WS-CHANNEL-ID PIC X(32).
       01 WS-STOP-FILE PIC X(512).
       01 WS-WAIT-MS PIC 9(10) COMP-5 VALUE 20.

       PROCEDURE DIVISION.
       MAIN.
           INITIALIZE DC-CONFIG
           ACCEPT DC-BOT-TOKEN FROM ENVIRONMENT "DISCORD_TOKEN"
           ACCEPT DC-CLIENT-ID FROM ENVIRONMENT "DISCORD_APPLICATION_ID"
           ACCEPT WS-GUILD-ID FROM ENVIRONMENT "DISCORD_GUILD_ID"
           ACCEPT WS-CHANNEL-ID FROM ENVIRONMENT "DISCORD_VOICE_CHANNEL_ID"
           ACCEPT WS-STOP-FILE FROM ENVIRONMENT "DISCORD_STOP_FILE"
           MOVE 129 TO DC-INTENTS
           IF FUNCTION TRIM(DC-BOT-TOKEN) = SPACES
              OR FUNCTION TRIM(WS-GUILD-ID) = SPACES
              OR FUNCTION TRIM(WS-CHANNEL-ID) = SPACES
               DISPLAY "DISCORD_TOKEN, DISCORD_GUILD_ID, and "
                   "DISCORD_VOICE_CHANNEL_ID are required"
               STOP RUN RETURNING 2
           END-IF

           CALL "DC-CLIENT-INIT" USING DC-CONFIG DC-CLIENT DC-RESULT
           PERFORM REQUIRE-OK
           CALL "DC-BOT-REGISTER-DEFAULTS" USING DC-CLIENT DC-RESULT
           PERFORM REQUIRE-OK
           CALL "DC-LOGIN" USING DC-CLIENT DC-RESULT
           PERFORM REQUIRE-OK
           CALL "DC-VOICE-JOIN"
               USING DC-CLIENT WS-GUILD-ID WS-CHANNEL-ID DC-RESULT
           PERFORM REQUIRE-OK

           IF FUNCTION TRIM(WS-STOP-FILE) = SPACES
               MOVE ".discord-cob.stop" TO WS-STOP-FILE
           END-IF
           DISPLAY "voice negotiation running; stop file: "
               FUNCTION TRIM(WS-STOP-FILE)
           CALL "DC-BOT-RUN-UNTIL-FILE"
               USING DC-CLIENT WS-STOP-FILE WS-WAIT-MS DC-RESULT
           PERFORM REQUIRE-OK
           CALL "DC-BOT-SHUTDOWN" USING DC-CLIENT DC-RESULT
           PERFORM REQUIRE-OK
           STOP RUN RETURNING 0.

       REQUIRE-OK.
           IF DC-STATUS-CODE NOT = DC-STATUS-OK
               DISPLAY FUNCTION TRIM(DC-ERROR-CODE)
               DISPLAY FUNCTION TRIM(DC-ERROR-MESSAGE)
               STOP RUN RETURNING 1
           END-IF.
       END PROGRAM EXAMPLE-VOICE-JOIN.
