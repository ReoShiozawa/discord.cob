       IDENTIFICATION DIVISION.
       PROGRAM-ID. DC-NONCE-INIT.

       DATA DIVISION.
       LINKAGE SECTION.
       COPY "discord-crypto.cpy".
       COPY "discord-result.cpy".

       PROCEDURE DIVISION USING DC-NONCE-STATE DC-RESULT.
       MAIN.
           MOVE 0 TO DC-NONCE-COUNTER
           MOVE LOW-VALUE TO DC-NONCE-BUFFER
           CALL "DC-RESULT-OK" USING DC-RESULT
           GOBACK.
       END PROGRAM DC-NONCE-INIT.

       IDENTIFICATION DIVISION.
       PROGRAM-ID. DC-NONCE-NEXT.

       DATA DIVISION.
       WORKING-STORAGE SECTION.
       78 DC-NONCE-MAX-COUNTER VALUE 4294967295.
       01 WS-B1 PIC 9(10) COMP-5.
       01 WS-B2 PIC 9(10) COMP-5.
       01 WS-B3 PIC 9(10) COMP-5.
       01 WS-B4 PIC 9(10) COMP-5.

       LINKAGE SECTION.
       COPY "discord-crypto.cpy".
       COPY "discord-result.cpy".

       PROCEDURE DIVISION USING DC-NONCE-STATE DC-RESULT.
       MAIN.
           MOVE LOW-VALUE TO DC-NONCE-BUFFER
           COMPUTE WS-B1 = FUNCTION INTEGER(DC-NONCE-COUNTER / 16777216)
           COMPUTE WS-B2 =
               FUNCTION INTEGER(
                   FUNCTION MOD(DC-NONCE-COUNTER, 16777216) / 65536)
           COMPUTE WS-B3 =
               FUNCTION INTEGER(FUNCTION MOD(DC-NONCE-COUNTER, 65536) / 256)
           COMPUTE WS-B4 = FUNCTION MOD(DC-NONCE-COUNTER, 256)
           MOVE FUNCTION CHAR(WS-B1 + 1) TO DC-NONCE-BUFFER(1:1)
           MOVE FUNCTION CHAR(WS-B2 + 1) TO DC-NONCE-BUFFER(2:1)
           MOVE FUNCTION CHAR(WS-B3 + 1) TO DC-NONCE-BUFFER(3:1)
           MOVE FUNCTION CHAR(WS-B4 + 1) TO DC-NONCE-BUFFER(4:1)
           IF DC-NONCE-COUNTER >= DC-NONCE-MAX-COUNTER
               MOVE 0 TO DC-NONCE-COUNTER
           ELSE
               ADD 1 TO DC-NONCE-COUNTER
           END-IF
           CALL "DC-RESULT-OK" USING DC-RESULT
           GOBACK.
       END PROGRAM DC-NONCE-NEXT.
